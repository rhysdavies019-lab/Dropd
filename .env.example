# ─── Supabase ───────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Public key goes in the frontend (VITE_ prefix exposes it to the browser)
VITE_STRIPE_PUBLIC_KEY=pk_live_your-stripe-public-key

# ─── Cloudflare Worker (server-side secrets — never expose to browser) ───────
# Set these via: wrangler secret put STRIPE_SECRET_KEY
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── OpenPageRank (free tier — 100 requests/day) ─────────────────────────────
# Sign up free at: https://www.openpagerank.com
# Gives real backlink counts + domain authority scores
VITE_OPR_API_KEY=your-openpagerank-api-key

# ─── App config ──────────────────────────────────────────────────────────────
VITE_APP_URL=https://dropd.io
